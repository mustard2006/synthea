# Supabase (required) — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Local auth redirect (optional; defaults work for localhost:3000)
NEXT_PUBLIC_DEV_SUPABASE_REDIRECT_URL=http://localhost:3000/auth/callback

# Personal app: only this email can sign up / sign in (recommended in production)
ALLOWED_EMAIL=you@example.com

# --- AI provider: gemini (free) or azure ---
# Set AI_PROVIDER to force one; otherwise gemini wins if both keys exist.
AI_PROVIDER=gemini

# Google Gemini (free tier) — https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=
# Free-tier friendly default; see https://ai.google.dev/gemini-api/docs/models
GEMINI_MODEL=gemini-2.5-flash

# Azure OpenAI (optional; GitHub Student Pack)
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_RESOURCE_NAME=
# AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
# AZURE_OPENAI_API_VERSION=2024-08-01-preview
